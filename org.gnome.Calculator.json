{
    "id": "org.gnome.Calculator",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "gnome-calculator",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--share=network",
        "--metadata=X-DConf=migrate-path=/org/gnome/calculator/"
    ],
    "cleanup": [
        "/bin/gcalccmd",
        "/include",
        "/share/info",
        "/share/man",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "mpc",
            "config-opts": [
                "--with-mpfr=/app"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://ftp.gnu.org/gnu/mpc/mpc-1.3.1.tar.gz",
                    "sha256": "ab642492f5cf882b74aa0cb730cd410a81edcdbec895183ce930e706c1c759b8",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 1667,
                        "url-template": "https://ftp.gnu.org/gnu/mpc/mpc-$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "gnome-calculator",
            "buildsystem": "meson",
            "config-opts": [
                "-Dgcalc=false",
                "-Ddisable-introspection=true"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/gnome-calculator/50/gnome-calculator-50.0.tar.xz",
                    "sha256": "8053d6891565e882874b65c1db51c5bf310005eb788b8bac3546390743350a90",
                    "x-checker-data": {
                        "type": "gnome",
                        "name": "gnome-calculator"
                    }
                }
            ]
        }
    ]
}
